<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>#(title)</title>
  
    <link rel="stylesheet" href="/css/bootstrap-grid.min.css?v=5.3.8">
    <link rel="stylesheet" href="/css/bootstrap-utilities.min.css?v=5.3.8">
    <link rel="stylesheet" href="/css/common.css?v=1">
    <link rel="stylesheet" href="/css/main.css?v=1">
</head>

<body>
    <nav class="top-nav container">
        <a href="/">Home</a>
        #if(username):
            <div class="user-info">
                <span>Welcome, #(username)!</span>
                <a href="/account/logout">Logout</a>
            </div>
        #else:
            <a href="/account/sign-up">Sign Up</a>
            <a href="/account/login">Login</a>
        #endif
    </nav>

    #import("body")
</body>
</html>
